<% if(success && success.length > 0){ %>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        if(typeof Toastify !== 'undefined') {
            Toastify({
                text: "<%= success %>",
                duration: 3000,
                close: true,
                gravity: "bottom",
                position: "right",
                style: {
                    background: "var(--primary)",
                    color: "#fff",
                    borderRadius: "8px",
                    fontWeight: "600",
                    boxShadow: "0 10px 25px rgba(0,0,0,0.1)"
                }
            }).showToast();
        }
    });
</script>
<% } %>

<% if(error && error.length > 0){ %>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        if(typeof Toastify !== 'undefined') {
            Toastify({
                text: "<%= error %>",
                duration: 4000,
                close: true,
                gravity: "bottom",
                position: "right",
                style: {
                    background: "var(--accent)",
                    color: "#fff",
                    borderRadius: "8px",
                    fontWeight: "600",
                    boxShadow: "0 10px 25px rgba(0,0,0,0.1)"
                }
            }).showToast();
        }
    });
</script>
<% } %>
