<% layout('layouts/boilerplate') %>
<div class="container auth-wrapper">
  <div class="auth-card">
    <div class="auth-card-inner">
      <h3 class="auth-title">Join WanderLust</h3>
      
      <form action="/signup" method="post" novalidate class="needs-validation">
        <div class="mb-4">
          <label for="username" class="form-label">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            class="form-control"
            required
            minlength="3"
            maxlength="30"
            pattern="[a-zA-Z0-9]+"
            placeholder="Choose a username"
          />
          <div class="invalid-feedback">Username must be 3-30 characters (letters/numbers only).</div>
        </div>

        <div class="mb-4">
          <label for="email" class="form-label">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-control"
            required
            placeholder="Enter your email"
          />  
          <div class="invalid-feedback">Please provide a valid email address.</div>
        </div>
        
        <div class="mb-5">
          <label for="password" class="form-label">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="form-control"
            required
            minlength="6"
            placeholder="Create a password (min 6 characters)"
          />
          <div class="invalid-feedback">Password must be at least 6 characters long.</div>
        </div>
        
        <button type="submit" class="btn btn-primary btn-lg rounded-pill">Sign Up</button>
      </form>

      <div class="text-center mt-4 pt-3 border-top" style="opacity: 0.8;">
        <p class="mb-0" style="font-weight: 500;">Already have an account? <a href="/login" class="text-dark fw-bold text-decoration-underline">Log in</a></p>
      </div>
    </div>
  </div>
</div>

<script>
// Bootstrap form validation
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>
