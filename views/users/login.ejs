<% layout('layouts/boilerplate') %>
<div class="container auth-wrapper">
  <div class="auth-card">
    <div class="auth-card-inner">
      <h3 class="auth-title">Welcome back</h3>
      
      <form action="/login" method="post" novalidate class="needs-validation">
        <div class="mb-4">
          <label for="username" class="form-label">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            class="form-control"
            required
            placeholder="Enter your username"
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Username is required.</div>
        </div>

        <div class="mb-5">
          <label for="password" class="form-label">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            class="form-control"
            required
            placeholder="Enter your password"
          />
          <div class="valid-feedback">Looks good!</div>          
          <div class="invalid-feedback">Password is required.</div>
        </div>
        
        <button type="submit" class="btn btn-primary btn-lg rounded-pill">Log in</button>
      </form>
      
      <div class="text-center mt-4 pt-3 border-top" style="opacity: 0.8;">
        <p class="mb-0" style="font-weight: 500;">Don't have an account? <a href="/signup" class="text-dark fw-bold text-decoration-underline">Sign up</a></p>
      </div>
    </div>
  </div>
</div>

<script>
// Bootstrap form validation
(function() {
  'use strict';
  window.addEventListener('load', function() {
    var forms = document.getElementsByClassName('needs-validation');
    var validation = Array.prototype.filter.call(forms, function(form) {
      form.addEventListener('submit', function(event) {
        if (form.checkValidity() === false) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  }, false);
})();
</script>
