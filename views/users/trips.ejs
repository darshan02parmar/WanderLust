<% layout('layouts/boilerplate') %>

<div class="container my-5 px-lg-5">
    <h2 class="fw-bold mb-4">Trips</h2>
    
    <ul class="nav nav-tabs mb-4 border-bottom-0" id="tripsTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold border-0 text-dark" id="upcoming-tab" data-bs-toggle="tab" data-bs-target="#upcoming" type="button" role="tab" style="border-bottom: 2px solid #111 !important; border-radius: 0;">Upcoming</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold border-0 text-muted" id="past-tab" data-bs-toggle="tab" data-bs-target="#past" type="button" role="tab">Past</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold border-0 text-muted" id="cancelled-tab" data-bs-toggle="tab" data-bs-target="#cancelled" type="button" role="tab">Cancelled</button>
        </li>
    </ul>

    <div class="tab-content" id="tripsTabContent">
        <!-- Upcoming Trips -->
        <div class="tab-pane fade show active" id="upcoming" role="tabpanel">
            <% if (upcomingTrips.length === 0) { %>
                <div class="text-center py-5 border-0 rounded-4" style="background: #f8f9fa;">
                    <img src="https://images.unsplash.com/photo-1503220317375-aaad61436b1b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="empty trips" class="mb-4 rounded-circle" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid #fff; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">
                    <h4 class="fw-bold">No trips booked... yet!</h4>
                    <p class="text-muted mb-4">Time to dust off your bags and start planning your next adventure.</p>
                    <a href="/listings" class="btn btn-dark px-5 py-3 fw-bold rounded-pill">Start searching</a>
                </div>
            <% } else { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% for (let booking of upcomingTrips) { %>
                        <div class="col">
                            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                                <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="listing image" style="height: 200px; object-fit: cover;">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-1"><%= booking.listing.title %></h5>
                                    <p class="text-muted small"><%= booking.listing.location %></p>
                                    <hr class="text-muted">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted small fw-bold">DATES</span>
                                        <span class="small fw-bold"><%= booking.checkIn.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %> - <%= booking.checkOut.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small fw-bold">TOTAL PAID</span>
                                        <span class="small fw-bold">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                    </div>
                                </div>
                                <div class="card-footer bg-white border-0 p-4 pt-0 text-center">
                                    <div class="d-flex gap-2 mb-2">
                                        <a href="/bookings/<%= booking._id %>/confirmation" class="btn btn-dark w-50 rounded-pill fw-bold" style="font-size: 0.9rem;">View</a>
                                        <a href="mailto:host@wanderlust.com" class="btn btn-outline-dark w-50 rounded-pill fw-bold" style="font-size: 0.9rem;">Contact</a>
                                    </div>
                                    <form action="/bookings/<%= booking._id %>/cancel?_method=PATCH" method="POST">
                                        <button type="submit" class="btn btn-outline-danger w-100 rounded-pill fw-bold" style="font-size: 0.9rem;">Cancel Reservation</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>

        <!-- Past Trips -->
        <div class="tab-pane fade" id="past" role="tabpanel">
            <% if (pastTrips.length === 0) { %>
                <div class="text-center py-5">
                    <p class="text-muted">You have no past trips.</p>
                </div>
            <% } else { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% for (let booking of pastTrips) { %>
                        <div class="col">
                            <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden opacity-75">
                                <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="listing image" style="height: 150px; object-fit: cover; filter: grayscale(50%);">
                                <div class="card-body p-4">
                                    <h6 class="fw-bold mb-1"><%= booking.listing.title %></h6>
                                    <p class="text-muted small mb-2"><%= booking.checkIn.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                    <a href="/listings/<%= booking.listing._id %>" class="btn btn-dark btn-sm rounded-pill mt-2">Book Again</a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>

        <!-- Cancelled Trips -->
        <div class="tab-pane fade" id="cancelled" role="tabpanel">
            <% if (cancelledTrips.length === 0) { %>
                <div class="text-center py-5">
                    <p class="text-muted">You have no cancelled trips.</p>
                </div>
            <% } else { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% for (let booking of cancelledTrips) { %>
                        <div class="col">
                            <div class="card border border-danger shadow-sm rounded-4 h-100 overflow-hidden bg-light opacity-75">
                                <div class="card-body p-4">
                                    <div class="badge bg-danger mb-3">Cancelled</div>
                                    <h6 class="fw-bold mb-1"><%= booking.listing.title %></h6>
                                    <p class="text-muted small mb-0"><%= booking.listing.location %></p>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    // Tab switching style logic
    document.querySelectorAll('.nav-link').forEach(tab => {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.nav-link').forEach(t => {
                t.classList.remove('text-dark');
                t.classList.add('text-muted');
                t.style.borderBottom = 'none';
            });
            this.classList.remove('text-muted');
            this.classList.add('text-dark');
            this.style.borderBottom = '2px solid #111';
        });
    });
</script>
